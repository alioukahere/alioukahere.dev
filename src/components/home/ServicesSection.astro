---
interface Props {
  translations: {
    title: string
    description: string
    items: {
      backend: { title: string; description: string }
      webApps: { title: string; description: string }
      consulting: { title: string; description: string }
    }
  }
}

const { translations } = Astro.props
const services = [
  translations.items.backend,
  translations.items.webApps,
  translations.items.consulting,
]
---

<section class="section-padding border-t border-gray-200 dark:border-gray-800">
  <h2 class="section-title">{translations.title}</h2>
  <p class="section-description">{translations.description}</p>
  <div class="grid md:grid-cols-3 gap-8">
    {services.map((service) => (
      <div class="p-8 rounded-lg bg-gray-50 dark:bg-gray-800">
        <h3 class="text-xl font-semibold mb-4 leading-snug">
          {service.title}
        </h3>
        <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
          {service.description}
        </p>
      </div>
    ))}
  </div>
</section>
