            {tech.name === 'Laravel' && (
              <svg class="w-12 h-12 text-gray-700 dark:text-gray-300" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M23.642 5.43a.364.364 0 01.014.1v5.149c0 .135-.073.26-.189.326l-4.323 2.49v4.934c0 .135-.073.26-.189.326l-9.03 5.206a.32.32 0 01-.065.028.32.32 0 01-.065.028c-.022.007-.045.012-.068.013h-.013a.357.357 0 01-.15-.034L.534 18.975a.378.378 0 01-.189-.326V3.363c0-.035.005-.069.014-.1l.002-.006a.36.36 0 01.023-.063l.006-.012a.376.376 0 01.035-.054l.008-.01a.388.388 0 01.046-.046l.012-.008a.379.379 0 01.054-.035l9.03-5.206a.378.378 0 01.378 0l9.03 5.206a.352.352 0 01.054.035l.012.01a.375.375 0 01.046.044l.008.012a.374.374 0 01.035.054l.006.012a.33.33 0 01.023.063l.002.006zM22.084 10.49V6.004l-1.816 1.047-2.507 1.446v4.487l4.323-2.494zM17.57 20.88V16.4l-2.465 1.408-6.939 3.96v4.536l9.404-5.423zM1.126 3.83v14.82l8.65 4.99v-4.539L5.457 16.71l-.005-.003-.005-.002c-.022-.013-.04-.028-.059-.044l-.008-.007a.384.384 0 01-.043-.046l-.006-.01a.376.376 0 01-.032-.06l-.003-.008a.316.316 0 01-.018-.065v-.003a.31.31 0 01-.005-.069V6.484L3.461 5.037 1.126 3.83zm8.84-2.95L2.08 5.07l7.886 4.55 7.886-4.55-7.886-4.19zM5.66 15.897l3.898 2.24V9.626L7.743 8.18 5.66 7.086v8.81zm14.606-9.898l-4.514 2.603-4.514 2.603V16.2l7.213-4.117 1.815-1.048V5.999z"/>
              </svg>
            )}
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-white">
              {tech.name}
            </h3>
            <span class="text-sm text-gray-600 dark:text-gray-300">
              {tech.years} {common.yearsExperience}
            </span>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
