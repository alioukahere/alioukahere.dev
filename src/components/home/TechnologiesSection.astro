---
interface Props {
  translations: {
    title: string
  }
  common: {
    yearsExperience: string
  }
}

const { translations, common } = Astro.props

const technologies = [
  { name: 'Symfony', years: 7 },
  { name: 'React', years: 5 },
  { name: 'Laravel', years: 3 },
]
---

<section class="section-padding border-t border-gray-200 dark:border-gray-800">
  <h2 class="section-title">{translations.title}</h2>
  <div class="grid md:grid-cols-3 gap-8">
    {technologies.map((tech) => (
      <div class="p-6 rounded-lg border border-gray-200 dark:border-gray-700 flex flex-col bg-gray-50 dark:bg-gray-800">
        <div class="flex items-center gap-6">
          <div class="w-12 h-12 flex items-center justify-center">
            {tech.name === 'Symfony' && (
