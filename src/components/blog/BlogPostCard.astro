---
import { formatDate } from '@/lib/utils'
import type { BlogPost, Locale } from '@/types'

interface Props {
  post: BlogPost
  locale: Locale
  common: {
    readMore: string
  }
  languageNames?: {
    en: string
    fr: string
  }
}

const { post, locale, common, languageNames } = Astro.props
const blogUrl = `/${locale}/blog/${post.slug}`
---

<article class="rounded-lg bg-gray-50 dark:bg-gray-800/50 transition-all duration-200 overflow-hidden">
  <div class="p-8">
  <div class="mb-6 flex flex-wrap gap-2">
    <span class="px-4 py-1.5 text-sm bg-blue-100/80 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full font-medium">
      {post.category}
    </span>
    {post.isFallback && languageNames && (
      <span class="px-4 py-1.5 text-sm bg-amber-100/80 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 rounded-full font-medium">
        {languageNames[post.locale]}
      </span>
    )}
  </div>

  <a href={blogUrl}>
    <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 leading-snug hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200">
      {post.title}
    </h3>
  </a>

  <p class="text-gray-600 dark:text-gray-300 mb-6 leading-relaxed line-clamp-3">
    {post.excerpt}
  </p>

  <div class="flex justify-between items-center">
    <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
      <time datetime={post.publishedAt}>
        {formatDate(post.publishedAt, locale)}
      </time>
      <span class="hidden sm:inline-block">&bull;</span>
      <span class="hidden sm:inline-block">{post.readingTime}</span>
    </div>

    <a
      href={blogUrl}
      class="font-medium inline-flex items-center transition-colors duration-200 group"
    >
      {common.readMore}{' '}
      <span class="ml-1 transform transition-transform group-hover:translate-x-0.5">
        &rarr;
      </span>
    </a>
  </div>
  </div>
</article>
