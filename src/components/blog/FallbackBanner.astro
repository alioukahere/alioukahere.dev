---
import type { Locale } from '@/types'

interface Props {
  contentLocale: Locale
  translations: {
    message: string
  }
  languageNames: {
    en: string
    fr: string
  }
}

const { contentLocale, translations, languageNames } = Astro.props
const languageName = languageNames[contentLocale]
---

<div class="mb-8 p-4 rounded-lg bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800">
  <span class="dark:text-white">
    &#127757; {translations.message}{' '}
    <span class="font-semibold">{languageName}</span>
  </span>
</div>
